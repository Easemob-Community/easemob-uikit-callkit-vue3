{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@easemob/callkit-core": ["../callkit-core/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "src/**/*.tsx"]
}
