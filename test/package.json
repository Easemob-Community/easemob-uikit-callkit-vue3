{
  "name": "easemob-chat-callkit-vue3-test",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm run dev:source",
    "dev:source": "vite --config vite.config.source.ts",
    "dev:tgz": "vite --config vite.config.tgz.ts",
    "switch:source": "node scripts/switch-mode.mjs source && pnpm install",
    "switch:tgz": "node scripts/switch-mode.mjs tgz && pnpm install",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "agora-rtc-sdk-ng": "^4.24.2",
    "easemob-websdk": "^4.16.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.18"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.7.0",
    "typescript": "~5.8.3",
    "vite": "^7.1.2",
    "vue-tsc": "^3.0.5"
  }
}
