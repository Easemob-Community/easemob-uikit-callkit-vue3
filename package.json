{
  "name": "easemob-chat-callkit-vue3",
  "version": "0.0.1",
  "type": "module",
  "description": "Easemob Chat CallKit Vue3 Plugin",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "test": "cd test && pnpm dev"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.7.0",
    "typescript": "~5.8.3",
    "vite": "^7.1.2",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.18",
    "vue-tsc": "^3.0.5"
  },
  "packageManager": "pnpm@10.10.0",
  "dependencies": {
    "agora-rtc-sdk-ng": "^4.24.2",
    "easemob-websdk": "^4.16.0",
    "pinia": "^3.0.3"
  }
}
