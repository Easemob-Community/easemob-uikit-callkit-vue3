/* Header 样式 */
.call-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 60px;
  padding: 0 16px;
  color: #ffffff;
  border-bottom: 1px solid rgba(255, 255, 255, 0.15);
}

.header-content {
  display: flex;
  align-items: center;
  gap: 12px;
}

.group-avatar {
  width: 40px;
  height: 40px;
  border-radius: 4px;
  object-fit: cover;
}

.header-info h3 {
  margin: 0;
  font-size: 16px;
  font-weight: 500;
}

.call-duration {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.7);
}

.header-actions {
  display: flex;
  gap: 8px;
}

.icon-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  border: none;
  border-radius: 4px;
  background: rgba(255, 255, 255, 0.15);
  color: #ffffff;
  cursor: pointer;
  font-size: 14px;
  transition: background 0.2s;
}

.icon-btn svg {
  flex-shrink: 0;
}

.icon-btn:hover {
  background: rgba(255, 255, 255, 0.25);
}

/* 响应式 */
@media (max-width: 768px) {
  .call-header {
    padding: 0 12px;
  }
  
  .header-info h3 {
    font-size: 14px;
  }
  
  .call-duration {
    font-size: 12px;
  }
  
  .icon-btn {
    padding: 6px 12px;
    font-size: 12px;
  }
}
